# ==========================================
# 大语言模型配置 (DeepSeek AI 润色)
# ==========================================

# 请在此填入您的真实 DeepSeek API Key (如 sk-xxxxxxxxxxxxxxx)
LLM_API_KEY="sk-edf76fc6fed2411988d4d0ba3e1e5228"

# DeepSeek 官方接口地址
LLM_BASE_URL="https://api.deepseek.com"

# 推荐使用的润色模型 (deepseek-chat)
LLM_MODEL="deepseek-chat"

# ==========================================
# 本地推理模型权重存储路径 (相对路径或绝对路径)
# ==========================================

# 预训练的 YOLOv5 手语识别子模型 (原始 FP32 格式，适合带独立显卡 GPU 的机器使用)
HAND_WEIGHTS="runs/hand_detect_yolov5s_b32/weights/best.pt"
DIGIT_WEIGHTS="runs/digits_detect_yolov5b64/weights/best.pt"
LETTER_WEIGHTS="runs/letters_detect_yolov5m_v12/weights/best.pt"

# 高级优化：专为不带满血显卡的普通 PC / 核显 准备的 INT8 极限加速级模型
HAND_WEIGHTS_ONNX="runs/hand_detect_yolov5s_b32/weights/best_int8.onnx"
DIGIT_WEIGHTS_ONNX="runs/digits_detect_yolov5b64/weights/best_int8.onnx"
LETTER_WEIGHTS_ONNX="runs/letters_detect_yolov5m_v12/weights/best_int8.onnx"

# Google MediaPipe 源生手部骨骼检测模型
MEDIAPIPE_TASK="mediapipe/hand_landmarker.task"

# ==========================================
# CPU 推理性能优化 (仅无 GPU 时生效)
# ==========================================
# 抽帧策略: 2 表示每两帧推理一次，1 表示不跳帧
CPU_PERF_FRAME_SKIP=2
# 推理分辨率: 如果觉得卡可设为 320 或 416，0 为不缩小 (原始 640)
CPU_PERF_IMGSZ=320
