<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.diy.sys.mapper.Question.QuestionSetQuestionMapper">
    <select id="getQuestionIdsByQuestionSetId" resultType="Integer" parameterType="Integer">
        select question_id
        from x_set_question
        where set_id = #{questionSetId}
    </select>
</mapper>

