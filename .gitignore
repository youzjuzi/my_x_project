# ===================================================================
# General: Editor, OS, and Environment Files
# These rules apply to the entire project repository.
# ===================================================================

# Editor/OS specific files (apply to root and all subdirectories)
.idea/
.vscode/
*.swp
*~
.DS_Store

# Environment variables - NEVER commit secrets!
#.env
#.env.*
#!.env.example


# ===================================================================
# Backend: Java (x-admin)
# Rules specific to the 'x-admin' backend sub-project.
# ===================================================================

# Compiled output from Maven/Gradle
x-admin/target/
x-admin/build/

# Spring Boot specific
x-admin/HELP.md

# Maven Wrapper - Do NOT ignore the wrapper jar
!x-admin/.mvn/wrapper/maven-wrapper.jar

# IDE specific files for Java projects
x-admin/.apt_generated
x-admin/.classpath
x-admin/.factorypath
x-admin/.project
x-admin/.settings/
x-admin/.springBeans
x-admin/.sts4-cache
x-admin/*.iws
x-admin/*.iml
x-admin/*.ipr

# NetBeans specific
x-admin/nbproject/private/
x-admin/nbbuild/
x-admin/dist/
x-admin/nbdist/
x-admin/.nb-gradle/


# ===================================================================
# Frontend: Vue (admin-web)
# Rules specific to the 'admin-web' frontend sub-project.
# gitignore for admin-web frontend
# ===================================================================

admin-web/

# Dependencies
#admin-web/node_modules/
#
## Build output
#admin-web/dist/
#
## Logs
#admin-web/npm-debug.log*
#admin-web/yarn-debug.log*
#admin-web/yarn-error.log*
#
## Test coverage reports
#admin-web/tests/**/coverage/

# ===================================================================
# Frontend: Vue (web-vue3)
# Rules specific to the 'web-vue3' frontend sub-project.
# ===================================================================
# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
coverage
*.local

/cypress/videos/
/cypress/screenshots/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

*.tsbuildinfo

# 自动生成的类型声明文件
web-vue3/auto-imports.d.ts
web-vue3/components.d.ts

# ===================================================================
# Tauri (web-vue3/src-tauri)
# Rules specific to Tauri desktop app build outputs.
# ===================================================================

# Rust build output
web-vue3/src-tauri/target/

# Generated schemas
web-vue3/src-tauri/gen/

# ===================================================================
# Python: YOLOv5 (my_yolov5_project)
# Rules specific to the 'my_yolov5_project' python sub-project.
# ===================================================================

# Python Virtual Environments
venv/
env/
.env/
.venv/
ENV/

# Python Cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Datasets and Large Files (YOLO specifics)
my_yolov5_project/datasets/
my_yolov5_project/*.pt
my_yolov5_project/*.onnx
my_yolov5_project/*.zip
my_yolov5_project/*.tar
my_yolov5_project/*.gz

# Training Runs & Detections (generated artifacts)
my_yolov5_project/runs/

# Jupyter Notebook Checkpoints
.ipynb_checkpoints/

# Other build artifacts
build/
dist/
*.egg-info/
downloads/

# ===================================================================
# Logs & Runtime Files
# ===================================================================

# Application logs
x-admin/logs/
web-vue3/logs/

# ===================================================================
# Other Files to Ignore
# ===================================================================

# Windows batch files (only useful locally)
*.bat
# 忽略本地数据库数据
data/
web-vue3/components.d.ts
