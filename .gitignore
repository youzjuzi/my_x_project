# ===================================================================
# General: Editor, OS, and Environment Files
# These rules apply to the entire project repository.
# ===================================================================

# Editor/OS specific files (apply to root and all subdirectories)
.idea/
.vscode/
*.swp
*~
.DS_Store

# Environment variables - NEVER commit secrets!
#.env
#.env.*
#!.env.example


# ===================================================================
# Backend: Java (backend-java)
# Rules specific to the 'backend-java' backend sub-project.
# ===================================================================

# Compiled output from Maven/Gradle
backend-java/target/
backend-java/build/

# Spring Boot specific
backend-java/HELP.md

# Maven Wrapper - Do NOT ignore the wrapper jar
!backend-java/.mvn/wrapper/maven-wrapper.jar

# IDE specific files for Java projects
backend-java/.apt_generated
backend-java/.classpath
backend-java/.factorypath
backend-java/.project
backend-java/.settings/
backend-java/.springBeans
backend-java/.sts4-cache
backend-java/*.iws
backend-java/*.iml
backend-java/*.ipr

# NetBeans specific
backend-java/nbproject/private/
backend-java/nbbuild/
backend-java/dist/
backend-java/nbdist/
backend-java/.nb-gradle/


# ===================================================================
# Frontend: Vue (admin-web)
# Rules specific to the 'admin-web' frontend sub-project.
# gitignore for admin-web frontend
# ===================================================================

admin-web/

# Dependencies
#admin-web/node_modules/
#
## Build output
#admin-web/dist/
#
## Logs
#admin-web/npm-debug.log*
#admin-web/yarn-debug.log*
#admin-web/yarn-error.log*
#
## Test coverage reports
#admin-web/tests/**/coverage/

# ===================================================================
# Frontend: Vue (frontend-web)
# Rules specific to the 'frontend-web' frontend sub-project.
# ===================================================================
# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
coverage
*.local

/cypress/videos/
/cypress/screenshots/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

*.tsbuildinfo

# 自动生成的类型声明文件
frontend-web/auto-imports.d.ts
frontend-web/components.d.ts

# ===================================================================
# Tauri (frontend-web/src-tauri)
# Rules specific to Tauri desktop app build outputs.
# ===================================================================

# Rust build output
frontend-web/src-tauri/target/

# Generated schemas
frontend-web/src-tauri/gen/

# ===================================================================
# AI: Python/YOLOv5 (ai-server)
# Rules specific to the 'ai-server' python sub-project.
# ===================================================================

# Python Virtual Environments
venv/
env/
.env/
.venv/
ENV/

# Python Cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Datasets and Large Files (YOLO specifics)
ai-server/datasets/
ai-server/*.pt
ai-server/*.onnx
ai-server/*.zip
ai-server/*.tar
ai-server/*.gz

# Training Runs & Detections (generated artifacts)
ai-server/runs/

# Jupyter Notebook Checkpoints
.ipynb_checkpoints/

# Other build artifacts
build/
dist/
*.egg-info/
downloads/

# ===================================================================
# Logs & Runtime Files
# ===================================================================

# Application logs
backend-java/logs/
frontend-web/logs/

# ===================================================================
# Other Files to Ignore
# ===================================================================

# Windows batch files (only useful locally)
*.bat
# 忽略本地数据库数据
data/
frontend-web/components.d.ts
